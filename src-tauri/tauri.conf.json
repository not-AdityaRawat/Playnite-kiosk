{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Playnite",
  "version": "1.0.0",
  "identifier": "com.playnite.kiosk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Playnite",
        "fullscreen": true,
        "decorations": false,
        "alwaysOnTop": false,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data:; connect-src 'self' http://127.0.0.1:1420 ws://127.0.0.1:1420;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "windows": {
      "wix": null,
      "nsis": { "installMode": "perMachine" }
    }
  }
}
